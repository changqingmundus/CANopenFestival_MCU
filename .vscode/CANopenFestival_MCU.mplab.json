                "config.mcc/mcc_generated_files/system/src/where_was_i.s",
                "config.mcc/mcc_generated_files/spi_host/src/spi1.c",
                "config.mcc/mcc_generated_files/can/src/can1.c",
                "config.mcc/mcc_generated_files/system/src/dmt_asm.s",
                "config.mcc/mcc_generated_files/system/src/dmt.c",
